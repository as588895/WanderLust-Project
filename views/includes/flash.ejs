<!-- for the success -->
<% if(locals.success && locals.success.length) { %>
    <div class="alert alert-success alert-dismissible fade show col-6 offset-3" role="alert"> <%= locals.success %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aris-label="Close"></button>
    </div>
<% } %>

<!-- for the error -->
<% if(locals.error && locals.error.length) { %>
    <div class="alert alert-danger alert-dismissible fade show col-6 offset-3" role="alert"> <%= locals.error %>
    <button type="button" class="btn-close" data-bs-dismiss="alert" aris-label="Close"></button>
    </div>
<% } %>