<% layout("/layouts/boilerplate") %>

<div class="booking-success-wrap py-5">
  <div class="card border-0 shadow-sm success-card mx-auto">
    <div class="card-body p-4 p-md-5 text-center">
      <div class="success-icon mb-3">
        <i class="fa-solid fa-circle-check"></i>
      </div>
      <h2 class="mb-2">Booking Confirmed</h2>
      <p class="text-muted mb-4">Your payment is successful and reservation is now confirmed.</p>

      <div class="text-start booking-meta">
        <div class="d-flex justify-content-between border-bottom py-2">
          <span>Listing</span>
          <strong><%= booking.listing.title %></strong>
        </div>
        <div class="d-flex justify-content-between border-bottom py-2">
          <span>Dates</span>
          <strong><%= booking.checkIn.toDateString() %> to <%= booking.checkOut.toDateString() %></strong>
        </div>
        <div class="d-flex justify-content-between border-bottom py-2">
          <span>Guests</span>
          <strong><%= booking.guests %></strong>
        </div>
        <div class="d-flex justify-content-between border-bottom py-2">
          <span>Total paid</span>
          <strong>INR <%= booking.totalPrice.toLocaleString("en-IN") %></strong>
        </div>
        <div class="d-flex justify-content-between py-2">
          <span>Payment status</span>
          <strong class="text-success text-uppercase"><%= booking.paymentStatus %></strong>
        </div>
      </div>

      <div class="d-flex justify-content-center gap-2 mt-4 flex-wrap">
        <a href="/listings/<%= booking.listing._id %>" class="btn btn-outline-dark">View listing</a>
        <a href="/listings" class="btn btn-danger">Explore more</a>
      </div>
    </div>
  </div>
</div>
